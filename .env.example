# Optional. When both are set, Twitch is checked for real via the Helix API.
# Without them, Twitch results are reported as "unknown".
# Create an app at https://dev.twitch.tv/console/apps to get these.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Auth (Clerk) — required for accounts and per-user gating.
# Create a free app at https://dashboard.clerk.com and copy the API keys.
# Only the publishable key is public; keep the secret key server-side.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---------------------------------------------------------------------------
# Payments (Stripe) — server-side Checkout + webhook. ALL of these are secret
# server-only values. Never prefix them with NEXT_PUBLIC and never commit them.
# ---------------------------------------------------------------------------
# Secret key from https://dashboard.stripe.com/apikeys (use a test key in dev).
STRIPE_SECRET_KEY=
# Signing secret for your webhook endpoint (starts with whsec_). From the
# Stripe dashboard webhook, or `stripe listen` when testing locally.
STRIPE_WEBHOOK_SECRET=
# Recurring price IDs (price_…) for each paid plan's product in Stripe.
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# Absolute base URL of the deployment, used to build Checkout success/cancel
# URLs when the request Origin header is unavailable. e.g. https://availifyai.com
NEXT_PUBLIC_APP_URL=
